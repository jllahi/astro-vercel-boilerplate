{
	"name": "astro-vercel-boilerplate",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"packageManager": "bun@1.3.14",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"check": "astro check",
		"dev": "astro dev",
		"format": "bun x --bun @biomejs/biome format --write",
		"lint": "bun x --bun @biomejs/biome lint --write",
		"lint:unsafe": "bun x --bun @biomejs/biome lint --write --unsafe",
		"biome:check": "bun x --bun @biomejs/biome check --write",
		"preview": "astro preview",
		"start": "astro dev",
		"vercel:dev": "vercel dev",
		"vercel:link": "vercel link"
	},
	"dependencies": {
		"@astrojs/vercel": "^11.0.3",
		"@fontsource-variable/inter": "^5.2.8",
		"@picocss/pico": "^2.1.1",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"astro": "^7.0.9",
		"astro-seo": "^1.1.0",
		"typescript": "^7.0.2",
		"web-vitals": "^6.0.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"astro-meta-tags": "^0.4.1",
		"@biomejs/biome": "^2.5.3"
	}
}
